generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FINANCE
  SALES
  PROCUREMENT
  INVENTORY
  TRAINING
  AUDITOR
}

enum DocumentType {
  SALES_RECEIPT
  CASH_RECEIPT
  SALES_INVOICE
  PROFORMA_INVOICE
  QUOTATION
  DELIVERY_NOTE
  PAYMENT_VOUCHER
  IMPREST_VOUCHER
  EXPENSE_VOUCHER
  PURCHASE_RECEIPT
  PURCHASE_INVOICE
  LOAN_RECEIPT
  LOAN_REPAYMENT_RECEIPT
  SERVICE_COMPLETION_CERTIFICATE
}

enum DocumentStatus {
  OPEN
  PAID
  PARTIAL
  CANCELED
}

enum ApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  PAID
}

enum LoanStatus {
  ACTIVE
  CLOSED
  DEFAULTED
}

model User {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  password   String
  firstName  String
  lastName   String
  role       Role       @default(SALES)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  documents  Document[] @relation("CreatedBy")
  approvals  Document[] @relation("ApprovedBy")
  auditLogs  AuditLog[]
}

model Customer {
  id           Int        @id @default(autoincrement())
  name         String
  contactEmail String
  phone        String
  address      String
  tin          String?    
  notes        String?
  documents    Document[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Supplier {
  id           Int        @id @default(autoincrement())
  name         String
  contactEmail String
  phone        String
  address      String
  tin          String?    
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model InventoryItem {
  id          Int      @id @default(autoincrement())
  sku         String   @unique
  name        String
  category    String
  unit        String
  unitPrice   Decimal
  quantity    Int
  reorderLevel Int     @default(5)
  location    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id         Int          @id @default(autoincrement())
  reference  String       @unique
  category   String
  amount     Decimal
  date       DateTime
  paidBy     String
  status     ExpenseStatus @default(PENDING)
  notes      String?
  createdBy  User         @relation(fields: [createdById], references: [id])
  createdById Int
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Loan {
  id          Int           @id @default(autoincrement())
  borrower    String
  principal   Decimal
  outstanding Decimal
  interestRate Float
  currency     String        @default("NGN")
  dueDate      DateTime
  status       LoanStatus    @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  repayments   LoanRepayment[]
}

model LoanRepayment {
  id         Int      @id @default(autoincrement())
  loan       Loan     @relation(fields: [loanId], references: [id])
  loanId     Int
  amount     Decimal
  paidAt     DateTime @default(now())
  receiptRef String
  createdAt  DateTime @default(now())
}

model Document {
  id                Int              @id @default(autoincrement())
  docType           DocumentType
  reference         String           @unique
  customer          Customer?        @relation(fields: [customerId], references: [id])
  customerId        Int?
  supplier          Supplier?        @relation(fields: [supplierId], references: [id])
  supplierId        Int?
  issueDate         DateTime         @default(now())
  dueDate           DateTime?
  status            DocumentStatus   @default(OPEN)
  approvalStatus    ApprovalStatus   @default(DRAFT)
  currency          String           @default("NGN")
  totalAmount       Decimal
  vatAmount         Decimal
  discountAmount    Decimal
  amountPaid        Decimal
  balanceDue        Decimal
  transactionStatus String
  signedBy          String?
  customerSignatureUrl String?
  documentUrl       String?
  qrCodeData        String?
  lineItems         DocumentLineItem[]
  createdBy         User             @relation("CreatedBy", fields: [createdById], references: [id])
  createdById       Int
  approvedBy        User?            @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedById      Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model DocumentLineItem {
  id          Int      @id @default(autoincrement())
  document    Document @relation(fields: [documentId], references: [id])
  documentId  Int
  description String
  quantity    Int
  unit        String
  unitPrice   Decimal
  discount    Decimal
  vat         Decimal
  total       Decimal
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?
  timestamp DateTime @default(now())
  details   String?
}
