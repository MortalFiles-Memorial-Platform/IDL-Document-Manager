generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


model User {
  id            Int              @id @default(autoincrement())
  email         String           @unique
  password      String
  firstName     String
  lastName      String
  role          String           @default("SALES")
  department    String?          // Maps to role for access control: ADMIN, SALES, FINANCE, PROCUREMENT, AUDITOR
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  documents     Document[]       @relation("CreatedBy")
  approvals     Document[]       @relation("ApprovedBy")
  expenses      Expense[]
  auditLogs     AuditLog[]
  journalEntries JournalEntry[]
}

model Customer {
  id           Int        @id @default(autoincrement())
  name         String
  contactEmail String
  phone        String
  address      String
  tin          String?    
  notes        String?
  documents    Document[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Supplier {
  id           Int        @id @default(autoincrement())
  name         String
  contactEmail String
  phone        String
  address      String
  tin          String?
  notes        String?
  documents    Document[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model InventoryItem {
  id          Int      @id @default(autoincrement())
  sku         String   @unique
  name        String
  category    String
  unit        String
  unitPrice   Float
  quantity    Int
  reorderLevel Int     @default(5)
  location    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id         Int          @id @default(autoincrement())
  reference  String       @unique
  category   String
  amount     Float
  date       DateTime
  paidBy     String
  status     String       @default("PENDING")
  notes      String?
  createdBy  User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById Int
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Loan {
  id          Int           @id @default(autoincrement())
  borrower    String
  principal   Float
  outstanding Float
  interestRate Float
  currency     String        @default("NGN")
  dueDate      DateTime
  status       String        @default("ACTIVE")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  repayments   LoanRepayment[]
}

model LoanRepayment {
  id         Int      @id @default(autoincrement())
  loan       Loan     @relation(fields: [loanId], references: [id])
  loanId     Int
  amount     Float
  paidAt     DateTime @default(now())
  receiptRef String
  createdAt  DateTime @default(now())
}

model Document {
  id                   Int                @id @default(autoincrement())
  docType              String
  reference            String             @unique
  customer             Customer?          @relation(fields: [customerId], references: [id])
  customerId           Int?
  supplier             Supplier?          @relation(fields: [supplierId], references: [id])
  supplierId           Int?
  issueDate            DateTime           @default(now())
  dueDate              DateTime?
  status               String             @default("OPEN")
  approvalStatus       String             @default("DRAFT")
  currency             String             @default("NGN")
  totalAmount          Float
  vatAmount            Float
  discountAmount       Float
  amountPaid           Float
  balanceDue           Float
  transactionStatus    String
  signedBy             String?
  customerSignatureUrl String?
  documentUrl          String?
  qrCodeData           String?
  lineItems            DocumentLineItem[]
  journalEntries       JournalEntry[]
  createdBy            User               @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById          Int
  approvedBy           User?              @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: Cascade)
  approvedById         Int?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model DocumentLineItem {
  id          Int      @id @default(autoincrement())
  document    Document @relation(fields: [documentId], references: [id])
  documentId  Int
  description String
  quantity    Int
  unit        String
  unitPrice   Float
  discount    Float
  vat         Float
  total       Float
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int?
  timestamp DateTime @default(now())
  details   String?
}

model ChartOfAccounts {
  id              Int             @id @default(autoincrement())
  code            String          @unique
  name            String
  type            String          // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  balance         Float           @default(0)
  currency        String          @default("NGN")
  isActive        Boolean         @default(true)
  debitEntries    JournalEntry[]  @relation("Debit")
  creditEntries   JournalEntry[]  @relation("Credit")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model JournalEntry {
  id              Int             @id @default(autoincrement())
  reference       String
  description     String
  entryDate       DateTime
  debitAccountId  Int
  creditAccountId Int
  amount          Float
  document        Document?       @relation(fields: [documentId], references: [id])
  documentId      Int?
  debitAccount    ChartOfAccounts @relation("Debit", fields: [debitAccountId], references: [id])
  creditAccount   ChartOfAccounts @relation("Credit", fields: [creditAccountId], references: [id])
  createdBy       User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById     Int
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

