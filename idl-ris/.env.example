# Supabase PostgreSQL Configuration for Render Deployment
# Get connection string from: https://supabase.com/dashboard/project/ffmikbnryqpmjbzyldrf/settings/database

# For Production (Render + Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.ffmikbnryqpmjbzyldrf.supabase.co:5432/postgres?schema=public
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.ffmikbnryqpmjbzyldrf.supabase.co:5432/postgres

# For Local Development (with local PostgreSQL or SQLite)
# DATABASE_URL=file:./dev.db
# DATABASE_URL=postgresql://postgres:password@localhost:5432/idl_ris_dev

# Application Settings
NODE_ENV=production
PORT=3000

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=8h

# AWS S3 Configuration (optional - for document uploads)
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=idl-documents

# Email Configuration (optional - for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Notes for Render Deployment:
# 1. Set DATABASE_URL and DIRECT_URL in Render dashboard environment variables
# 2. Replace [PASSWORD] with actual Supabase database password
# 3. DATABASE_URL includes ?schema=public for connection pooling
# 4. DIRECT_URL is used by Prisma for migrations
# 5. Never commit this file with real credentials to git - use Render secrets
# 6. The build runs: npm run build (no DB access)
# 7. The start runs: npm run db:migrate:deploy && npm run start (DB access happens here)
