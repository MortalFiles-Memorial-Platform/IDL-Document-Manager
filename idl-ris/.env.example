# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=8h

# Database
# Local development
# DATABASE_URL=file:./dev.db

# Production (PostgreSQL)
# Render: postgres://user:password@host:port/database
# Railway: postgresql://user:password@host:port/database
# Fly.io: postgres://user:password@host/database
DATABASE_URL=postgresql://user:password@localhost:5432/idl_documents

# Server Port (Render/Railway/Fly.io may override this)
PORT=4000

# API Configuration
NODE_ENV=production
VITE_BACKEND_URL=https://your-backend-url.com

# Optional: AWS S3 Configuration (if using cloud storage)
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=idl-documents

# Optional: Email Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
